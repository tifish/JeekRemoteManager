<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:JeekRemoteManager.ViewModels"
        xmlns:models="using:JeekRemoteManager.Models"
        xmlns:views="using:JeekRemoteManager.Views"
        xmlns:l="using:Jeek.Avalonia.Localization"
        mc:Ignorable="d" d:DesignWidth="1040" d:DesignHeight="680"
        x:Class="JeekRemoteManager.Views.MainWindow"
        x:Name="Root"
        x:DataType="vm:MainWindowViewModel"
        Width="1040" Height="680"
        MinWidth="760" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/icon.ico"
        Title="{l:Localize WindowTitle}"
        Background="{DynamicResource AppBackgroundBrush}">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#EEF2F6" />
                    <SolidColorBrush x:Key="ChromeSurfaceBrush" Color="#FBFCFE" />
                    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="SurfaceAltBrush" Color="#F6F8FA" />
                    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="PopupSurfaceBrush" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="PopupBorderBrush" Color="#B9C4D0" />
                    <SolidColorBrush x:Key="BorderBrushSoft" Color="#D4DCE5" />
                    <SolidColorBrush x:Key="BorderBrushStrong" Color="#AEBBC8" />
                    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#17212B" />
                    <SolidColorBrush x:Key="TextMutedBrush" Color="#657385" />
                    <SolidColorBrush x:Key="AccentBrush" Color="#0F766E" />
                    <SolidColorBrush x:Key="AccentHoverBrush" Color="#0B5F59" />
                    <SolidColorBrush x:Key="AccentSoftBrush" Color="#DFF4EE" />
                    <SolidColorBrush x:Key="SshIconBackgroundBrush" Color="#DBEAFE" />
                    <SolidColorBrush x:Key="SshIconBorderBrush" Color="#93C5FD" />
                    <SolidColorBrush x:Key="SshIconBrush" Color="#1D4ED8" />
                    <SolidColorBrush x:Key="ToolbarDuplicateIconBrush" Color="#2563EB" />
                    <SolidColorBrush x:Key="ToolbarScriptIconBrush" Color="#D97706" />
                    <SolidColorBrush x:Key="ToolbarAiIconBrush" Color="#16A34A" />
                    <SolidColorBrush x:Key="ToolbarFileBrowserIconBrush" Color="#0284C7" />
                    <SolidColorBrush x:Key="ToolbarMonitorIconBrush" Color="#7C3AED" />
                    <SolidColorBrush x:Key="ToolbarKeyIconBrush" Color="#CA8A04" />
                    <SolidColorBrush x:Key="HoverBrush" Color="#EEF6F4" />
                    <SolidColorBrush x:Key="SelectedBrush" Color="#E6F4F1" />
                    <SolidColorBrush x:Key="SelectedBorderBrush" Color="#8CCFC3" />
                    <SolidColorBrush x:Key="TerminalBackgroundBrush" Color="#101820" />
                    <SolidColorBrush x:Key="TerminalForegroundBrush" Color="#DCE7EF" />
                    <SolidColorBrush x:Key="SuccessBrush" Color="#15803D" />
                    <SolidColorBrush x:Key="DangerBrush" Color="#C2410C" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#111417" />
                    <SolidColorBrush x:Key="ChromeSurfaceBrush" Color="#171B20" />
                    <SolidColorBrush x:Key="SurfaceBrush" Color="#1C2229" />
                    <SolidColorBrush x:Key="SurfaceAltBrush" Color="#222A32" />
                    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#151A1F" />
                    <SolidColorBrush x:Key="PopupSurfaceBrush" Color="#1A2027" />
                    <SolidColorBrush x:Key="PopupBorderBrush" Color="#46515E" />
                    <SolidColorBrush x:Key="BorderBrushSoft" Color="#303943" />
                    <SolidColorBrush x:Key="BorderBrushStrong" Color="#4C5967" />
                    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F2F5F7" />
                    <SolidColorBrush x:Key="TextMutedBrush" Color="#A4AFBB" />
                    <SolidColorBrush x:Key="AccentBrush" Color="#2DD4BF" />
                    <SolidColorBrush x:Key="AccentHoverBrush" Color="#5EEAD4" />
                    <SolidColorBrush x:Key="AccentSoftBrush" Color="#123B38" />
                    <SolidColorBrush x:Key="SshIconBackgroundBrush" Color="#123A66" />
                    <SolidColorBrush x:Key="SshIconBorderBrush" Color="#60A5FA" />
                    <SolidColorBrush x:Key="SshIconBrush" Color="#BFDBFE" />
                    <SolidColorBrush x:Key="ToolbarDuplicateIconBrush" Color="#93C5FD" />
                    <SolidColorBrush x:Key="ToolbarScriptIconBrush" Color="#F59E0B" />
                    <SolidColorBrush x:Key="ToolbarAiIconBrush" Color="#86EFAC" />
                    <SolidColorBrush x:Key="ToolbarFileBrowserIconBrush" Color="#38BDF8" />
                    <SolidColorBrush x:Key="ToolbarMonitorIconBrush" Color="#C4B5FD" />
                    <SolidColorBrush x:Key="ToolbarKeyIconBrush" Color="#FACC15" />
                    <SolidColorBrush x:Key="HoverBrush" Color="#243332" />
                    <SolidColorBrush x:Key="SelectedBrush" Color="#1F3B39" />
                    <SolidColorBrush x:Key="SelectedBorderBrush" Color="#2DD4BF" />
                    <SolidColorBrush x:Key="TerminalBackgroundBrush" Color="#070B10" />
                    <SolidColorBrush x:Key="TerminalForegroundBrush" Color="#D8E2EA" />
                    <SolidColorBrush x:Key="SuccessBrush" Color="#4ADE80" />
                    <SolidColorBrush x:Key="DangerBrush" Color="#FB7185" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
            <SolidColorBrush x:Key="AccentForegroundBrush" Color="#FFFFFF" />
        </ResourceDictionary>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>
        <Style Selector="TextBlock.page-title">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>
        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>
        <Style Selector="TextBlock.label">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBlock.hint">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style Selector="Border.panel">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style Selector="Border.form-card">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="13" />
        </Style>
        <Style Selector="Border.icon-tile">
            <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SelectedBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style Selector="Border.status-pill">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="9,3" />
        </Style>
        <Style Selector="Border.tree-row">
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="6,4" />
            <!-- Reserve the border so the drag-over highlight doesn't shift the row. -->
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
        <Style Selector="Border.tree-row.drag-over">
            <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        </Style>
        <Style Selector="Border.connection-icon-badge">
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Border.connection-icon-badge.ssh-connection-icon">
            <Setter Property="Background" Value="{DynamicResource SshIconBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SshIconBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="TextBlock.connection-icon.ssh-connection-icon">
            <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, monospace" />
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource SshIconBrush}" />
        </Style>
        <Style Selector="Button">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SelectedBorderBrush}" />
        </Style>
        <Style Selector="Button:pressed">
            <Setter Property="Background" Value="{DynamicResource SelectedBrush}" />
        </Style>
        <Style Selector="Button.toolbar">
            <Setter Property="Background" Value="{DynamicResource ChromeSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="TextBlock.toolbar-action-icon">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Width" Value="16" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
        </Style>
        <Style Selector="TextBlock.toolbar-action-icon.duplicate">
            <Setter Property="Foreground" Value="{DynamicResource ToolbarDuplicateIconBrush}" />
        </Style>
        <Style Selector="TextBlock.toolbar-action-icon.script">
            <Setter Property="Foreground" Value="{DynamicResource ToolbarScriptIconBrush}" />
        </Style>
        <Style Selector="TextBlock.toolbar-action-icon.ai">
            <Setter Property="Foreground" Value="{DynamicResource ToolbarAiIconBrush}" />
        </Style>
        <Style Selector="TextBlock.toolbar-action-icon.file-browser">
            <Setter Property="Foreground" Value="{DynamicResource ToolbarFileBrowserIconBrush}" />
        </Style>
        <Style Selector="TextBlock.toolbar-action-icon.monitor">
            <Setter Property="Foreground" Value="{DynamicResource ToolbarMonitorIconBrush}" />
        </Style>
        <Style Selector="TextBlock.toolbar-action-icon.key">
            <Setter Property="Foreground" Value="{DynamicResource ToolbarKeyIconBrush}" />
        </Style>
        <Style Selector="TextBlock.toolbar-action-icon.connect">
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
        </Style>
        <Style Selector="TextBlock.toolbar-action-icon.edit">
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
        </Style>
        <Style Selector="Button.icon-button">
            <Setter Property="MinWidth" Value="36" />
            <Setter Property="Width" Value="36" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.font-step-button">
            <Setter Property="MinWidth" Value="44" />
            <Setter Property="Width" Value="44" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Border.font-size-display">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="10,4" />
        </Style>
        <Style Selector="TextBlock.font-size-value">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBlock.font-size-unit">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.tab-close">
            <Setter Property="MinWidth" Value="22" />
            <Setter Property="MinHeight" Value="22" />
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.tab-close:pointerover">
            <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
        </Style>
        <Style Selector="Button.accent">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button.accent:pointerover">
            <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}" />
        </Style>
        <Style Selector="TextBox">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="Padding" Value="9,6" />
        </Style>
        <Style Selector="TextBox:focus">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        </Style>
        <Style Selector="TextBox.output">
            <Setter Property="Background" Value="{DynamicResource TerminalBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TerminalForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushStrong}" />
        </Style>
        <Style Selector="TextBox.tree-name-editor">
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
        </Style>
        <Style Selector="ComboBox:focus">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        </Style>
        <Style Selector="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>
        <Style Selector="TreeView">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="TreeViewItem">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>
        <Style Selector="TreeViewItem:selected">
            <Setter Property="Background" Value="{DynamicResource SelectedBrush}" />
        </Style>
        <Style Selector="TabItem">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="2,2" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
        </Style>
        <Style Selector="TabItem:selected">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Border.tab-pill">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Padding" Value="9,4" />
            <Setter Property="MinHeight" Value="28" />
        </Style>
        <Style Selector="TabItem:pointerover Border.tab-pill">
            <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
        </Style>
        <Style Selector="TabItem:selected Border.tab-pill">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SelectedBorderBrush}" />
        </Style>
        <Style Selector="TabItem.terminal-tab.dragging Border.tab-pill">
            <Setter Property="Opacity" Value="0.72" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        </Style>
        <Style Selector="TextBlock.tab-label">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="TabItem:selected TextBlock.tab-label">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="MenuFlyoutPresenter">
            <Setter Property="Background" Value="{DynamicResource PopupSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PopupBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="7" />
        </Style>
        <Style Selector="ContextMenu">
            <Setter Property="Background" Value="{DynamicResource PopupSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PopupBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="7" />
        </Style>
        <Style Selector="MenuItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="10,6" />
        </Style>
        <Style Selector="TextBlock.menu-icon">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Width" Value="16" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
        </Style>
        <Style Selector="TextBlock.menu-icon.emoji">
            <Setter Property="FontFamily" Value="Segoe UI Emoji" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style Selector="TextBlock.menu-icon.accent">
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
        </Style>
        <Style Selector="TextBlock.menu-icon.danger">
            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
        </Style>
        <Style Selector="TextBlock.menu-icon.duplicate">
            <Setter Property="Foreground" Value="{DynamicResource ToolbarDuplicateIconBrush}" />
        </Style>
        <Style Selector="TextBlock.menu-icon.script">
            <Setter Property="Foreground" Value="{DynamicResource ToolbarScriptIconBrush}" />
        </Style>
        <Style Selector="TextBlock.menu-icon.ai">
            <Setter Property="Foreground" Value="{DynamicResource ToolbarAiIconBrush}" />
        </Style>
        <Style Selector="TextBlock.menu-icon.file-browser">
            <Setter Property="Foreground" Value="{DynamicResource ToolbarFileBrowserIconBrush}" />
        </Style>
        <Style Selector="TextBlock.menu-icon.monitor">
            <Setter Property="Foreground" Value="{DynamicResource ToolbarMonitorIconBrush}" />
        </Style>
        <Style Selector="TextBlock.menu-icon.key">
            <Setter Property="Foreground" Value="{DynamicResource ToolbarKeyIconBrush}" />
        </Style>
        <Style Selector="TextBlock.menu-icon.connect">
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
        </Style>
        <Style Selector="TextBlock.menu-icon.edit">
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
        </Style>
        <Style Selector="MenuItem:pointerover">
            <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>
        <!-- Compact command bar: when the window is too narrow to fit every button
             with its label, the code-behind adds the "compact" class and the buttons
             fall back to icon-only (each still has a tooltip). -->
        <Style Selector="Grid#CommandBar.compact TextBlock.toolbar-label">
            <Setter Property="IsVisible" Value="False" />
        </Style>
        <!-- Panel toggle buttons: read as an "on" toggle while their panel is
             visible, so the two states are obvious at a glance. Only the tree
             toggle recolors its icon — the terminal panel toggles keep their
             per-feature icon colors. -->
        <Style Selector="Button.toolbar.panel-on">
            <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SelectedBorderBrush}" />
        </Style>
        <Style Selector="Button#ToggleTreePanelButton.panel-on TextBlock.toolbar-action-icon">
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
        </Style>
    </Window.Styles>

    <DockPanel Background="{DynamicResource AppBackgroundBrush}">
        <!-- Command bar -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource ChromeSurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrushSoft}"
                BorderThickness="0,0,0,1"
                Padding="18,10">
            <Grid x:Name="CommandBar" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="18">
                <StackPanel x:Name="ToolbarBrand" Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Border Width="38" Height="38" Classes="icon-tile">
                        <Image Source="/Assets/icon.png"
                               Width="30"
                               Height="30"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                    </Border>
                    <Button x:Name="ToggleTreePanelButton"
                            Click="OnToggleConnectionPanelClick"
                            ToolTip.Tip="{l:Localize ToggleConnectionPanel}"
                            Classes="toolbar icon-button panel-on">
                        <TextBlock x:Name="ToggleTreePanelIcon"
                                   Classes="toolbar-action-icon"
                                   Text="&#xE89F;"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>
                </StackPanel>

                <StackPanel x:Name="ToolbarNew" Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Command="{Binding NewFolderCommand}" ToolTip.Tip="{l:Localize NewFolder}" Classes="toolbar">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <Border Classes="connection-icon-badge">
                                <TextBlock Classes="connection-icon emoji"
                                           Text="&#x1F4C1;"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Classes="toolbar-label" Text="{l:Localize Folder}" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NewSshCommand}" ToolTip.Tip="{l:Localize NewSsh}" Classes="toolbar">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <Border Classes="connection-icon-badge ssh-connection-icon">
                                <TextBlock Classes="connection-icon ssh-connection-icon"
                                           Text=">_"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Classes="toolbar-label" Text="{l:Localize SSH}" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NewWslCommand}" ToolTip.Tip="{l:Localize NewWsl}" Classes="toolbar">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <Border Classes="connection-icon-badge">
                                <TextBlock Classes="connection-icon emoji"
                                           Text="&#x1F427;"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Classes="toolbar-label" Text="{l:Localize WSL}" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NewRdpCommand}" ToolTip.Tip="{l:Localize NewRdp}" Classes="toolbar">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <Border Classes="connection-icon-badge">
                                <TextBlock Classes="connection-icon emoji"
                                           Text="&#x1F5A5;"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Classes="toolbar-label" Text="{l:Localize RDP}" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel x:Name="ToolbarTerminal" Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Click="OnDuplicateSessionToolbarClick"
                            ToolTip.Tip="{l:Localize DuplicateSession}"
                            IsVisible="{Binding IsTerminalActive}"
                            Classes="toolbar">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <TextBlock Classes="toolbar-action-icon duplicate" Text="&#xE8C8;" />
                            <TextBlock Classes="toolbar-label" Text="{l:Localize DuplicateSessionShort}" />
                        </StackPanel>
                    </Button>
                    <Button Click="OnRunScriptTerminalToolbarClick"
                            ToolTip.Tip="{l:Localize RunScript}"
                            IsVisible="{Binding IsTerminalActive}"
                            Classes="toolbar">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <TextBlock Classes="toolbar-action-icon script" Text="&#xE756;" />
                            <TextBlock Classes="toolbar-label" Text="{l:Localize RunScriptShort}" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="MonitorToolbarButton"
                            Click="OnMonitorToolbarClick"
                            ToolTip.Tip="{l:Localize ServerMonitorTooltip}"
                            IsVisible="{Binding IsTerminalActive}"
                            Classes="toolbar">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <TextBlock Classes="toolbar-action-icon monitor" Text="&#xE9D2;" />
                            <TextBlock Classes="toolbar-label" Text="{l:Localize ServerMonitor}" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="AiPanelToolbarButton"
                            Click="OnAiPanelToolbarClick"
                            ToolTip.Tip="{l:Localize AiAssistant}"
                            IsVisible="{Binding IsTerminalActive}"
                            Classes="toolbar">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <TextBlock Classes="toolbar-action-icon ai" Text="&#xE99A;" />
                            <TextBlock Classes="toolbar-label" Text="{l:Localize AiAssistantShort}" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="FileBrowserToolbarButton"
                            Click="OnFileBrowserToolbarClick"
                            ToolTip.Tip="{l:Localize FileBrowserTooltip}"
                            IsVisible="{Binding IsTerminalActive}"
                            Classes="toolbar">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <TextBlock Classes="toolbar-action-icon file-browser" Text="&#xE8B7;" />
                            <TextBlock Classes="toolbar-label" Text="{l:Localize FileBrowserShort}" />
                        </StackPanel>
                    </Button>
                    <Button Click="OnCopyPublicKeyTerminalToolbarClick"
                            ToolTip.Tip="{l:Localize CopyPublicKeyToServerTooltip}"
                            IsVisible="{Binding IsTerminalActive}"
                            Classes="toolbar icon-button">
                        <TextBlock Classes="toolbar-action-icon key"
                                   Text="&#xE8D7;"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>
                    <StackPanel Orientation="Horizontal"
                                Spacing="6"
                                VerticalAlignment="Center"
                                IsVisible="{Binding IsTerminalActive}">
                        <Button Command="{Binding DecreaseTerminalFontCommand}"
                                ToolTip.Tip="{l:Localize FontDecrease}"
                                Classes="toolbar font-step-button">
                            <TextBlock Text="A-"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Button>
                        <Border Classes="font-size-display">
                            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                <TextBlock Text="{Binding TerminalFontSize}" Classes="font-size-value" />
                                <TextBlock Text="pt" Classes="font-size-unit" />
                            </StackPanel>
                        </Border>
                        <Button Command="{Binding IncreaseTerminalFontCommand}"
                                ToolTip.Tip="{l:Localize FontIncrease}"
                                Classes="toolbar font-step-button">
                            <TextBlock Text="A+"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Button>
                    </StackPanel>
                    <Button ToolTip.Tip="{l:Localize MoreActions}" Classes="toolbar icon-button">
                        <Button.Content>
                            <TextBlock Classes="icon"
                                       Text="&#xE712;"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       TextAlignment="Center" />
                        </Button.Content>
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuItem Header="{l:Localize Settings}"
                                          Command="{Binding OpenSettingsCommand}"
                                          ToolTip.Tip="{l:Localize SettingsTooltip}">
                                    <MenuItem.Icon>
                                        <TextBlock Classes="menu-icon" Text="&#xE713;" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator />
                                <MenuItem Header="{l:Localize ImportFromFinalShell}"
                                          Command="{Binding ImportFinalShellCommand}">
                                    <MenuItem.Icon>
                                        <TextBlock Classes="menu-icon" Text="&#xE8B5;" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator />
                                <MenuItem Header="{l:Localize CheckForUpdates}"
                                          Command="{Binding CheckForUpdatesCommand}">
                                    <MenuItem.Icon>
                                        <TextBlock Classes="menu-icon accent" Text="&#xE895;" />
                                    </MenuItem.Icon>
                                </MenuItem>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom"
                Padding="18,7"
                Background="{DynamicResource ChromeSurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrushSoft}"
                BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Border Width="7" Height="7" CornerRadius="4" Background="{DynamicResource AccentBrush}" />
                    <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" />
                </StackPanel>
                <Border Grid.Column="1" Classes="status-pill" Margin="16,0,0,0">
                    <TextBlock Text="{Binding VersionDisplay}" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextMutedBrush}" />
                </Border>
            </Grid>
        </Border>

        <!-- Main area: tree | editor -->
        <Grid x:Name="MainGrid" ColumnDefinitions="306,Auto,*" Margin="10" ColumnSpacing="8">
            <Border x:Name="TreePanel" Grid.Column="0" Classes="panel" Padding="10">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="2,0,2,12">
                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Classes="page-title" Text="{l:Localize Connection}" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                VerticalAlignment="Center"
                                ToolTip.Tip="{l:Localize MoreActions}"
                                Classes="toolbar icon-button">
                            <Button.Content>
                                <TextBlock Classes="icon"
                                           Text="&#xE712;"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           TextAlignment="Center" />
                            </Button.Content>
                            <Button.Flyout>
                                <MenuFlyout>
                                    <MenuItem Header="{l:Localize Connect}" Command="{Binding ConnectCommand}">
                                        <MenuItem.Icon>
                                            <TextBlock Classes="menu-icon connect" Text="&#xE768;" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="{l:Localize ConnectNew}"
                                              Command="{Binding ConnectNewCommand}"
                                              IsVisible="{Binding IsShellConnectionContext}">
                                        <MenuItem.Icon>
                                            <TextBlock Classes="menu-icon connect" Text="&#xE8A7;" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="{l:Localize Edit}"
                                              Click="OnEditMenuClick"
                                              IsVisible="{Binding IsRegularConnectionContext}">
                                        <MenuItem.Icon>
                                            <TextBlock Classes="menu-icon edit" Text="&#xE70F;" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="{l:Localize RunScript}"
                                              Click="OnRunScriptMenuClick"
                                              IsVisible="{Binding IsShellSelectionContext}">
                                        <MenuItem.Icon>
                                            <TextBlock Classes="menu-icon script" Text="&#xE756;" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <Separator />
                                    <MenuItem Header="{l:Localize NewFolder}" Command="{Binding NewFolderCommand}">
                                        <MenuItem.Icon>
                                            <Border Classes="connection-icon-badge">
                                                <TextBlock Classes="connection-icon emoji"
                                                           Text="&#x1F4C1;"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="{l:Localize NewSsh}" Command="{Binding NewSshCommand}">
                                        <MenuItem.Icon>
                                            <Border Classes="connection-icon-badge ssh-connection-icon">
                                                <TextBlock Classes="connection-icon ssh-connection-icon"
                                                           Text=">_"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="{l:Localize NewWsl}" Command="{Binding NewWslCommand}">
                                        <MenuItem.Icon>
                                            <Border Classes="connection-icon-badge">
                                                <TextBlock Classes="connection-icon emoji"
                                                           Text="&#x1F427;"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="{l:Localize NewRdp}" Command="{Binding NewRdpCommand}">
                                        <MenuItem.Icon>
                                            <Border Classes="connection-icon-badge">
                                                <TextBlock Classes="connection-icon emoji"
                                                           Text="&#x1F5A5;"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <Separator />
                                    <MenuItem Header="{l:Localize Copy}" Command="{Binding CopyCommand}" InputGesture="Ctrl+C">
                                        <MenuItem.Icon>
                                            <TextBlock Classes="menu-icon duplicate" Text="&#xE8C8;" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="{l:Localize Cut}" Command="{Binding CutCommand}" InputGesture="Ctrl+X">
                                        <MenuItem.Icon>
                                            <TextBlock Classes="menu-icon" Text="&#xE8C6;" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="{l:Localize Paste}" Command="{Binding PasteCommand}" InputGesture="Ctrl+V">
                                        <MenuItem.Icon>
                                            <TextBlock Classes="menu-icon" Text="&#xE77F;" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <Separator />
                                    <MenuItem Header="{l:Localize Rename}" Command="{Binding RenameCommand}" InputGesture="F2">
                                        <MenuItem.Icon>
                                            <TextBlock Classes="menu-icon edit" Text="&#xE104;" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="{l:Localize Delete}" Command="{Binding DeleteCommand}" InputGesture="Delete">
                                        <MenuItem.Icon>
                                            <TextBlock Classes="menu-icon danger" Text="&#xE74D;" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                    </Grid>

                    <TreeView x:Name="Tree"
                              ItemsSource="{Binding Nodes}"
                              SelectionMode="Multiple"
                              SelectedItem="{Binding SelectedNode, Mode=TwoWay}">
                        <TreeView.Styles>
                            <!-- Keep each item's expand/collapse state bound to its view model
                                 so it can be preserved across tree reloads. -->
                            <Style Selector="TreeViewItem" x:DataType="vm:TreeNodeViewModel">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                            </Style>
                        </TreeView.Styles>
                        <TreeView.KeyBindings>
                            <KeyBinding Gesture="Ctrl+C" Command="{Binding CopyCommand}" />
                            <KeyBinding Gesture="Ctrl+X" Command="{Binding CutCommand}" />
                            <KeyBinding Gesture="Ctrl+V" Command="{Binding PasteCommand}" />
                            <KeyBinding Gesture="F2" Command="{Binding RenameCommand}" />
                            <KeyBinding Gesture="Delete" Command="{Binding DeleteCommand}" />
                            <KeyBinding Gesture="Escape" Command="{Binding ClearSelectionCommand}" />
                        </TreeView.KeyBindings>
                        <TreeView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{l:Localize Connect}" Command="{Binding ConnectCommand}"
                                          IsVisible="{Binding !IsRecentGroupContext}">
                                    <MenuItem.Icon>
                                        <TextBlock Classes="menu-icon connect" Text="&#xE768;" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="{l:Localize ConnectNew}" Command="{Binding ConnectNewCommand}"
                                          IsVisible="{Binding IsShellConnectionContext}">
                                    <MenuItem.Icon>
                                        <TextBlock Classes="menu-icon connect" Text="&#xE8A7;" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="{l:Localize Edit}" Click="OnEditMenuClick"
                                          IsVisible="{Binding IsRegularConnectionContext}">
                                    <MenuItem.Icon>
                                        <TextBlock Classes="menu-icon edit" Text="&#xE70F;" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="{l:Localize RunScript}" Click="OnRunScriptMenuClick"
                                          IsVisible="{Binding IsShellSelectionContext}">
                                    <MenuItem.Icon>
                                        <TextBlock Classes="menu-icon script" Text="&#xE756;" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="{l:Localize RevealInTree}" Command="{Binding RevealInTreeCommand}"
                                          IsVisible="{Binding IsRecentConnectionContext}">
                                    <MenuItem.Icon>
                                        <TextBlock Classes="menu-icon" Text="&#xE8DA;" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="{l:Localize RemoveFromRecent}" Command="{Binding RemoveFromRecentCommand}"
                                          IsVisible="{Binding IsRecentConnectionContext}">
                                    <MenuItem.Icon>
                                        <TextBlock Classes="menu-icon" Text="&#xE711;" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="{l:Localize ClearRecent}" Command="{Binding ClearRecentCommand}"
                                          IsVisible="{Binding IsRecentGroupContext}">
                                    <MenuItem.Icon>
                                        <TextBlock Classes="menu-icon danger" Text="&#xE74D;" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator IsVisible="{Binding IsRegularContext}" />
                                <MenuItem Header="{l:Localize NewFolder}" Command="{Binding NewFolderCommand}"
                                          IsVisible="{Binding IsRegularContext}">
                                    <MenuItem.Icon>
                                        <Border Classes="connection-icon-badge">
                                            <TextBlock Classes="connection-icon emoji"
                                                       Text="&#x1F4C1;"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="{l:Localize NewSsh}" Command="{Binding NewSshCommand}"
                                          IsVisible="{Binding IsRegularContext}">
                                    <MenuItem.Icon>
                                        <Border Classes="connection-icon-badge ssh-connection-icon">
                                            <TextBlock Classes="connection-icon ssh-connection-icon"
                                                       Text=">_"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="{l:Localize NewWsl}" Command="{Binding NewWslCommand}"
                                          IsVisible="{Binding IsRegularContext}">
                                    <MenuItem.Icon>
                                        <Border Classes="connection-icon-badge">
                                            <TextBlock Classes="connection-icon emoji"
                                                       Text="&#x1F427;"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="{l:Localize NewRdp}" Command="{Binding NewRdpCommand}"
                                          IsVisible="{Binding IsRegularContext}">
                                    <MenuItem.Icon>
                                        <Border Classes="connection-icon-badge">
                                            <TextBlock Classes="connection-icon emoji"
                                                       Text="&#x1F5A5;"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator IsVisible="{Binding IsRegularContext}" />
                                <MenuItem Header="{l:Localize Copy}" Command="{Binding CopyCommand}" InputGesture="Ctrl+C"
                                          IsVisible="{Binding IsRegularContext}">
                                    <MenuItem.Icon>
                                        <TextBlock Classes="menu-icon duplicate" Text="&#xE8C8;" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="{l:Localize Cut}" Command="{Binding CutCommand}" InputGesture="Ctrl+X"
                                          IsVisible="{Binding IsRegularContext}">
                                    <MenuItem.Icon>
                                        <TextBlock Classes="menu-icon" Text="&#xE8C6;" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="{l:Localize Paste}" Command="{Binding PasteCommand}" InputGesture="Ctrl+V"
                                          IsVisible="{Binding IsRegularContext}">
                                    <MenuItem.Icon>
                                        <TextBlock Classes="menu-icon" Text="&#xE77F;" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator IsVisible="{Binding IsRegularContext}" />
                                <MenuItem Header="{l:Localize Rename}" Command="{Binding RenameCommand}" InputGesture="F2"
                                          IsVisible="{Binding IsRegularContext}">
                                    <MenuItem.Icon>
                                        <TextBlock Classes="menu-icon edit" Text="&#xE104;" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="{l:Localize Delete}" Command="{Binding DeleteCommand}" InputGesture="Delete"
                                          IsVisible="{Binding IsRegularContext}">
                                    <MenuItem.Icon>
                                        <TextBlock Classes="menu-icon danger" Text="&#xE74D;" />
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </TreeView.ContextMenu>
                        <TreeView.ItemTemplate>
                            <TreeDataTemplate ItemsSource="{Binding Children}" x:DataType="vm:TreeNodeViewModel">
                                <Border Classes="tree-row" Opacity="{Binding NodeOpacity}"
                                        Classes.drag-over="{Binding IsDragOver}">
                                    <Grid ColumnDefinitions="26,*" ColumnSpacing="8">
                                        <Border Grid.Column="0"
                                                Classes="connection-icon-badge"
                                                Classes.ssh-connection-icon="{Binding IsSshConnection}">
                                            <TextBlock Classes="connection-icon emoji"
                                                       Classes.ssh-connection-icon="{Binding IsSshConnection}"
                                                       Text="{Binding Glyph}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Name}"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"
                                                   IsVisible="{Binding !IsNameEditing}" />
                                        <TextBox Grid.Column="1"
                                                 Classes="tree-name-editor"
                                                 Text="{Binding EditName, Mode=TwoWay}"
                                                 IsVisible="{Binding IsNameEditing}"
                                                 KeyDown="OnTreeNameEditorKeyDown"
                                                 LostFocus="OnTreeNameEditorLostFocus" />
                                    </Grid>
                                </Border>
                            </TreeDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </DockPanel>
            </Border>

            <GridSplitter x:Name="TreeSplitter" Grid.Column="1" Width="5" ResizeDirection="Columns"
                          Background="Transparent" />

            <!-- Right pane: fixed editor tab + terminal tabs added in code-behind -->
            <Border Grid.Column="2" Classes="panel" Padding="6" ClipToBounds="True">
            <TabControl x:Name="RightTabs"
                        SelectionChanged="OnRightTabsSelectionChanged">
                <TabItem x:Name="EditorTab">
                    <TabItem.Header>
                        <Border Classes="tab-pill">
                            <StackPanel Orientation="Horizontal" Spacing="7">
                                <TextBlock Classes="toolbar-action-icon edit" Text="&#xE70F;"
                                           IsVisible="{Binding !ShowBatchPanel}" />
                                <TextBlock Classes="toolbar-action-icon script" Text="&#xE756;"
                                           IsVisible="{Binding ShowBatchPanel}" />
                                <TextBlock Classes="tab-label" Text="{Binding EditorTabTitle}" />
                            </StackPanel>
                        </Border>
                    </TabItem.Header>
                    <Grid>
                <ContentControl Content="{Binding Editor}"
                                IsVisible="{Binding ShowConnectionEditor}">
                <ContentControl.DataTemplates>
                    <DataTemplate DataType="vm:ConnectionEditorViewModel">
                        <Grid>
                            <ScrollViewer>
                                <StackPanel Spacing="12" Margin="14,12,16,14">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Spacing="2">
                                            <TextBlock Classes="page-title" Text="{l:Localize Edit}" />
                                            <TextBlock Classes="hint" Text="{l:Localize AutoSaveHint}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                            <Button Command="{Binding #Root.((vm:MainWindowViewModel)DataContext).ConnectCommand}"
                                                    Classes="accent">
                                                <StackPanel Orientation="Horizontal" Spacing="7">
                                                    <TextBlock Classes="toolbar-action-icon connect" Text="&#xE768;" />
                                                    <TextBlock Text="{l:Localize Connect}" />
                                                </StackPanel>
                                            </Button>
                                            <Button Click="OnRunScriptMenuClick"
                                                    IsVisible="{Binding SupportsScripts}"
                                                    Classes="toolbar">
                                                <StackPanel Orientation="Horizontal" Spacing="7">
                                                    <TextBlock Classes="toolbar-action-icon script" Text="&#xE756;" />
                                                    <TextBlock Text="{l:Localize RunScript}" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Grid>

                                    <Border Classes="form-card">
                                        <StackPanel Spacing="12">
                                            <TextBlock Classes="section-title" Text="{l:Localize Connection}" />

                                            <Grid ColumnDefinitions="128,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10">
                                                <TextBlock Grid.Row="0" Grid.Column="0" Classes="label" Text="{l:Localize Type}" />
                                                <ComboBox Grid.Row="0" Grid.Column="1" HorizontalAlignment="Stretch"
                                                          ItemsSource="{Binding AvailableTypeDisplays}"
                                                          SelectedItem="{Binding TypeDisplay, Mode=TwoWay}" />

                                                <TextBlock Grid.Row="1" Grid.Column="0" Classes="label" Text="{l:Localize Name}" />
                                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Name, Mode=TwoWay}" />

                                                <TextBlock Grid.Row="2" Grid.Column="0" Classes="label" Text="{l:Localize Host}"
                                                           IsVisible="{Binding HasHostPort}" />
                                                <Grid Grid.Row="2" Grid.Column="1" ColumnDefinitions="*,86,96" ColumnSpacing="10"
                                                      IsVisible="{Binding HasHostPort}">
                                                    <TextBox Grid.Column="0" Text="{Binding Host, Mode=TwoWay}"
                                                             PlaceholderText="{l:Localize HostWatermark}" />
                                                    <TextBlock Grid.Column="1" Classes="label" Text="{l:Localize Port}"
                                                               HorizontalAlignment="Right" />
                                                    <TextBox Grid.Column="2" Text="{Binding Port, Mode=TwoWay}" />
                                                </Grid>

                                                <TextBlock Grid.Row="3" Grid.Column="0" Classes="label" Text="{l:Localize WslDistro}"
                                                           IsVisible="{Binding IsWsl}" />
                                                <StackPanel Grid.Row="3" Grid.Column="1" Spacing="6"
                                                            IsVisible="{Binding IsWsl}">
                                                    <ComboBox HorizontalAlignment="Stretch"
                                                              ItemsSource="{Binding AvailableWslDistros}"
                                                              SelectedItem="{Binding WslDistro, Mode=TwoWay}" />
                                                    <TextBlock Classes="hint" Text="{l:Localize WslNoDistros}"
                                                               Foreground="{DynamicResource DangerBrush}"
                                                               IsVisible="{Binding ShowNoWslDistrosHint}" />
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <Border Classes="form-card">
                                        <StackPanel Spacing="12">
                                            <TextBlock Classes="section-title" Text="{l:Localize Username}" />

                                            <Grid ColumnDefinitions="128,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                                                <TextBlock Grid.Row="0" Grid.Column="0" Classes="label" Text="{l:Localize Username}" />
                                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Username, Mode=TwoWay}" />

                                                <TextBlock Grid.Row="1" Grid.Column="0" Classes="label" Text="{l:Localize Password}"
                                                           IsVisible="{Binding HasPassword}" />
                                                <Grid Grid.Row="1" Grid.Column="1" ColumnDefinitions="*,Auto" ColumnSpacing="10"
                                                      IsVisible="{Binding HasPassword}">
                                                    <TextBox Grid.Column="0" x:Name="PasswordBox"
                                                             Text="{Binding Password, Mode=TwoWay}"
                                                             PasswordChar="&#x2022;"
                                                             RevealPassword="{Binding #Root.((vm:MainWindowViewModel)DataContext).ShowPassword}" />
                                                    <CheckBox Grid.Column="1" x:Name="ShowPasswordCheckBox"
                                                              Content="{l:Localize Show}"
                                                              VerticalAlignment="Center"
                                                              IsChecked="{Binding #Root.((vm:MainWindowViewModel)DataContext).ShowPassword, Mode=OneWay}"
                                                              Click="OnShowPasswordClick" />
                                                </Grid>

                                                <TextBlock Grid.Row="2" Grid.Column="1"
                                                           Text="{l:Localize PasswordDecryptFailed}"
                                                           Foreground="{DynamicResource DangerBrush}" TextWrapping="Wrap"
                                                           IsVisible="{Binding PasswordDecryptFailed}" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- SSH-specific -->
                                    <Border Classes="form-card"
                                            IsVisible="{Binding IsSsh}">
                                        <StackPanel Spacing="12">
                                            <TextBlock Classes="section-title" Text="{l:Localize SshOptions}" />
                                            <Grid ColumnDefinitions="128,*,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="10" ColumnSpacing="10">
                                                <TextBlock Grid.Row="0" Grid.Column="0" Classes="label" Text="{l:Localize TerminalType}" />
                                                <ComboBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                                                          HorizontalAlignment="Stretch"
                                                          ItemsSource="{Binding AvailableTerminalTypes}"
                                                          SelectedItem="{Binding TerminalType, Mode=TwoWay}" />

                                                <TextBlock Grid.Row="1" Grid.Column="0" Classes="label" Text="{l:Localize PrivateKey}" />
                                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding PrivateKeyPath, Mode=TwoWay}"
                                                         PlaceholderText="{l:Localize PrivateKeyWatermark}" />
                                                <Button Grid.Row="1" Grid.Column="2" Content="{l:Localize Browse}"
                                                        Command="{Binding #Root.((vm:MainWindowViewModel)DataContext).BrowseKeyCommand}" />

                                                <TextBlock Grid.Row="2" Grid.Column="0" Classes="label" Text="{l:Localize Passphrase}" />
                                                <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                                                         Text="{Binding PrivateKeyPassphrase, Mode=TwoWay}"
                                                         PasswordChar="&#x2022;"
                                                         RevealPassword="{Binding #Root.((vm:MainWindowViewModel)DataContext).ShowPassword}"
                                                         PlaceholderText="{l:Localize PassphraseWatermark}" />

                                                <TextBlock Grid.Row="3" Grid.Column="0" Classes="label" Text="{l:Localize LoginCommands}"
                                                           VerticalAlignment="Top" Margin="0,7,0,0" />
                                                <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2"
                                                         Text="{Binding LoginCommands, Mode=TwoWay}"
                                                         AcceptsReturn="True" TextWrapping="NoWrap" MinHeight="82"
                                                         PlaceholderText="{l:Localize LoginCommandsWatermark}" />

                                                <TextBlock Grid.Row="4" Grid.Column="0" Classes="label"
                                                           Text="{l:Localize AutoOpenPanels}" VerticalAlignment="Top" Margin="0,4,0,0" />
                                                <StackPanel Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2"
                                                            Orientation="Horizontal" Spacing="18">
                                                    <CheckBox Content="{l:Localize ServerMonitor}"
                                                              IsChecked="{Binding AutoOpenMonitorPanel, Mode=TwoWay}" />
                                                    <CheckBox Content="{l:Localize AiAssistantShort}"
                                                              IsChecked="{Binding AutoOpenAiPanel, Mode=TwoWay}" />
                                                    <CheckBox Content="{l:Localize FileBrowser}"
                                                              IsChecked="{Binding AutoOpenFileBrowserPanel, Mode=TwoWay}" />
                                                </StackPanel>
                                            </Grid>

                                        </StackPanel>
                                    </Border>

                                    <!-- WSL-specific -->
                                    <Border Classes="form-card"
                                            IsVisible="{Binding IsWsl}">
                                        <StackPanel Spacing="12">
                                            <TextBlock Classes="section-title" Text="{l:Localize WslOptions}" />
                                            <Grid ColumnDefinitions="128,*" RowDefinitions="Auto,Auto" RowSpacing="10">
                                                <TextBlock Grid.Row="0" Grid.Column="0" Classes="label" Text="{l:Localize WslStartDirectory}" />
                                                <TextBox Grid.Row="0" Grid.Column="1"
                                                         Text="{Binding WslStartDirectory, Mode=TwoWay}"
                                                         PlaceholderText="{l:Localize WslStartDirectoryWatermark}" />

                                                <TextBlock Grid.Row="1" Grid.Column="0" Classes="label" Text="{l:Localize LoginCommands}"
                                                           VerticalAlignment="Top" Margin="0,7,0,0" />
                                                <TextBox Grid.Row="1" Grid.Column="1"
                                                         Text="{Binding LoginCommands, Mode=TwoWay}"
                                                         AcceptsReturn="True" TextWrapping="NoWrap" MinHeight="82"
                                                         PlaceholderText="{l:Localize LoginCommandsWatermark}" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- RDP-specific -->
                                    <Border Classes="form-card"
                                            IsVisible="{Binding IsRdp}">
                                        <StackPanel Spacing="12">
                                            <TextBlock Classes="section-title" Text="{l:Localize RdpOptions}" />
                                            <StackPanel Orientation="Horizontal" Spacing="18">
                                                <CheckBox Content="{l:Localize FullScreen}"
                                                          IsChecked="{Binding RdpFullScreen, Mode=TwoWay}" />
                                                <CheckBox Content="{l:Localize UseAllMonitors}"
                                                          IsChecked="{Binding RdpUseAllMonitors, Mode=TwoWay}"
                                                          IsVisible="{Binding RdpFullScreen}" />
                                            </StackPanel>

                                            <Grid ColumnDefinitions="128,*,80,*" ColumnSpacing="10"
                                                  IsVisible="{Binding !RdpFullScreen}">
                                                <TextBlock Grid.Column="0" Classes="label" Text="{l:Localize Width}" />
                                                <TextBox Grid.Column="1" Text="{Binding RdpWidth, Mode=TwoWay}" />
                                                <TextBlock Grid.Column="2" Classes="label" Text="{l:Localize Height}"
                                                           HorizontalAlignment="Right" />
                                                <TextBox Grid.Column="3" Text="{Binding RdpHeight, Mode=TwoWay}" />
                                            </Grid>

                                            <TextBlock Classes="section-title" Text="{l:Localize LocalResources}" Margin="0,4,0,0" />
                                            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" RowSpacing="8" ColumnSpacing="14">
                                                <CheckBox Grid.Row="0" Grid.Column="0" Content="{l:Localize ShareClipboard}"
                                                          IsChecked="{Binding RdpRedirectClipboard, Mode=TwoWay}" />
                                                <CheckBox Grid.Row="0" Grid.Column="1" Content="{l:Localize ShareDrives}"
                                                          IsChecked="{Binding RdpRedirectDrives, Mode=TwoWay}" />
                                                <CheckBox Grid.Row="1" Grid.Column="0" Content="{l:Localize PlayRemoteAudio}"
                                                          IsChecked="{Binding RdpRedirectAudioPlayback, Mode=TwoWay}" />
                                                <CheckBox Grid.Row="1" Grid.Column="1" Content="{l:Localize ShareMicrophone}"
                                                          IsChecked="{Binding RdpRedirectMicrophone, Mode=TwoWay}" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <Border Classes="form-card">
                                        <Grid ColumnDefinitions="128,*">
                                            <TextBlock Grid.Column="0" Classes="label" Text="{l:Localize Notes}"
                                                       VerticalAlignment="Top" Margin="0,7,0,0" />
                                            <TextBox Grid.Column="1" Text="{Binding Notes, Mode=TwoWay}"
                                                     AcceptsReturn="True" TextWrapping="Wrap" MinHeight="82" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </DataTemplate>
                </ContentControl.DataTemplates>
            </ContentControl>

            <!-- Batch script run over the multi-selection -->
            <ContentControl Content="{Binding BatchPanel}"
                            IsVisible="{Binding ShowBatchPanel}">
                <ContentControl.DataTemplates>
                    <DataTemplate DataType="vm:BatchScriptPanelViewModel">
                        <views:BatchScriptPanelView />
                    </DataTemplate>
                </ContentControl.DataTemplates>
            </ContentControl>

            <!-- Placeholder when nothing is selected -->
            <Grid IsVisible="{Binding ShowPlaceholder}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="14" MaxWidth="360">
                    <Border Width="58" Height="58" Classes="icon-tile">
                        <Image Source="/Assets/icon.png"
                               Width="44"
                               Height="44"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Classes="page-title" Text="{l:Localize Connection}"
                               HorizontalAlignment="Center" />
                    <TextBlock Classes="hint"
                               Text="{Binding PlaceholderHint}"
                               TextAlignment="Center" />
                </StackPanel>
            </Grid>
                    </Grid>
                </TabItem>
            </TabControl>
            </Border>
        </Grid>
    </DockPanel>
</Window>
