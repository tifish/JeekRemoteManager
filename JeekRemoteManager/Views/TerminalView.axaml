<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="using:JeekRemoteManager.Models"
             xmlns:terminal="using:SvcSystems.UI.Terminal"
             xmlns:vm="using:JeekRemoteManager.ViewModels"
             xmlns:views="using:JeekRemoteManager.Views"
             xmlns:l="using:Jeek.Avalonia.Localization"
             x:Class="JeekRemoteManager.Views.TerminalView"
             x:Name="TerminalRoot"
             x:DataType="vm:MainWindowViewModel">
    <Grid x:Name="RootGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0" MinWidth="0" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" MinWidth="200" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="0" MinWidth="0" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" MinHeight="120" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="0" MinHeight="0" />
        </Grid.RowDefinitions>

        <Border x:Name="MonitorPanelHost"
                Grid.Column="0"
                Grid.RowSpan="3"
                IsVisible="False"
                BorderBrush="{DynamicResource BorderBrushSoft}"
                BorderThickness="0,0,1,0">
            <views:ServerMonitorView x:Name="MonitorPanel" />
        </Border>

        <GridSplitter x:Name="MonitorSplitter"
                      Grid.Column="1"
                      Grid.RowSpan="3"
                      Width="5"
                      ResizeDirection="Columns"
                      ResizeBehavior="PreviousAndNext"
                      Background="Transparent"
                      IsVisible="False" />

        <Grid x:Name="TerminalArea" Grid.Column="2" Grid.Row="0">
            <Grid.Styles>
                <Style Selector="Button.scroll-to-bottom">
                    <Setter Property="Width" Value="36" />
                    <Setter Property="Height" Value="36" />
                    <Setter Property="MinWidth" Value="0" />
                    <Setter Property="MinHeight" Value="0" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="CornerRadius" Value="18" />
                    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                    <Setter Property="VerticalContentAlignment" Value="Center" />
                    <Setter Property="Opacity" Value="0.92" />
                    <Setter Property="ZIndex" Value="10" />
                </Style>
                <Style Selector="Button.scroll-to-bottom:pointerover">
                    <Setter Property="Opacity" Value="1" />
                    <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
                </Style>
            </Grid.Styles>
            <terminal:TerminalControl x:Name="Term"
                                      RightClickAction="ContextMenu" />
            <!-- Shown when the viewport is scrolled away from the live bottom. -->
            <Button x:Name="ScrollToBottomButton"
                    Classes="scroll-to-bottom"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,28,16"
                    IsVisible="False"
                    Click="OnScrollToBottomClick"
                    ToolTip.Tip="{l:Localize ScrollToLatestHint}">
                <TextBlock FontFamily="Segoe MDL2 Assets"
                           FontSize="14"
                           Foreground="{DynamicResource AccentForegroundBrush}"
                           Text="&#xE74B;"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Button>
        </Grid>

        <GridSplitter x:Name="FileSplitter"
                      Grid.Column="2"
                      Grid.Row="1"
                      Height="5"
                      ResizeDirection="Rows"
                      ResizeBehavior="PreviousAndNext"
                      Background="Transparent"
                      IsVisible="False" />

        <Border x:Name="FileBrowserHost"
                Grid.Column="2"
                Grid.Row="2"
                IsVisible="False"
                BorderBrush="{DynamicResource BorderBrushSoft}"
                BorderThickness="0,1,0,0">
            <views:FileBrowserView x:Name="FileBrowser" />
        </Border>

        <GridSplitter x:Name="AiSplitter"
                      Grid.Column="3"
                      Grid.RowSpan="3"
                      Width="5"
                      ResizeDirection="Columns"
                      ResizeBehavior="PreviousAndNext"
                      Background="Transparent"
                      IsVisible="False" />

        <Border x:Name="AiPanelHost"
                Grid.Column="4"
                Grid.RowSpan="3"
                IsVisible="False"
                BorderBrush="{DynamicResource BorderBrushSoft}"
                BorderThickness="1,0,0,0">
            <views:AgentChatView x:Name="AiPanel" />
        </Border>

        <Border x:Name="ScriptPanelOverlay"
                Grid.Column="0"
                Grid.ColumnSpan="5"
                Grid.RowSpan="3"
                IsVisible="False"
                Background="#88000000"
                Padding="14">
            <Border Classes="panel"
                    Padding="12"
                    MaxWidth="760"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8">
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0"
                                   Classes="page-title"
                                   Text="{Binding ScriptPanel.SuiteName}" />
                        <Button Grid.Column="1"
                                Classes="toolbar icon-button"
                                ToolTip.Tip="{l:Localize Close}"
                                Command="{Binding CloseScriptExecutionCommand}">
                            <TextBlock Classes="icon"
                                       Text="&#xE711;"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       TextAlignment="Center" />
                        </Button>
                    </Grid>

                    <Border Grid.Row="1"
                            BorderBrush="{DynamicResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="8,6">
                        <ScrollViewer MinHeight="0"
                                      MaxHeight="260"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto">
                            <Grid ColumnDefinitions="*,156" ColumnSpacing="12">
                                <ItemsControl Grid.Column="0"
                                              ItemsSource="{Binding ScriptPanel.Parameters}"
                                              Grid.IsSharedSizeScope="True">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="vm:ScriptParameterValueViewModel">
                                            <Grid ColumnSpacing="10" Margin="0,3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"
                                                                      MinWidth="120"
                                                                      SharedSizeGroup="ScriptParamName" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Classes="label"
                                                           Text="{Binding Name}"
                                                           TextWrapping="Wrap" />
                                                <Grid Grid.Column="1">
                                                    <TextBox Text="{Binding Value, Mode=TwoWay}"
                                                             IsVisible="{Binding IsText}" />
                                                    <TextBox Text="{Binding Value, Mode=TwoWay}"
                                                             PasswordChar="&#x2022;"
                                                             IsVisible="{Binding IsSecret}" />
                                                    <CheckBox IsChecked="{Binding BoolValue, Mode=TwoWay}"
                                                              IsVisible="{Binding IsBool}" />
                                                    <ComboBox ItemsSource="{Binding EnumOptions}"
                                                              SelectedItem="{Binding SelectedEnumValue, Mode=TwoWay}"
                                                              IsVisible="{Binding IsEnum}" />
                                                </Grid>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <ItemsControl Grid.Column="1"
                                              ItemsSource="{Binding ScriptPanel.Scripts}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Vertical" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="models:RemoteScriptFile">
                                            <Button Content="{Binding DisplayName}"
                                                    Classes="toolbar"
                                                    HorizontalAlignment="Stretch"
                                                    HorizontalContentAlignment="Center"
                                                    Margin="0,0,0,6"
                                                    Command="{Binding #TerminalRoot.((vm:MainWindowViewModel)DataContext).RunScriptFileCommand}"
                                                    CommandParameter="{Binding}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </ScrollViewer>
                    </Border>

                    <Grid Grid.Row="2" ColumnDefinitions="Auto,*" ColumnSpacing="9" MinHeight="30">
                        <Grid Grid.Column="0"
                              Width="24"
                              Height="24"
                              VerticalAlignment="Center"
                              IsVisible="{Binding ScriptPanel.ShowResultIcon}">
                            <TextBlock Classes="icon"
                                       Text="&#xE73E;"
                                       FontSize="22"
                                       Foreground="{DynamicResource SuccessBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       TextAlignment="Center"
                                       IsVisible="{Binding ScriptPanel.ShowSuccessIcon}" />
                            <TextBlock Classes="icon"
                                       Text="&#xE711;"
                                       FontSize="22"
                                       Foreground="{DynamicResource DangerBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       TextAlignment="Center"
                                       IsVisible="{Binding ScriptPanel.ShowFailureIcon}" />
                        </Grid>
                        <TextBlock Grid.Column="1"
                                   Classes="hint"
                                   Text="{Binding ScriptPanel.StatusText}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <Button Grid.Row="3"
                            Classes="toolbar"
                            HorizontalAlignment="Left"
                            Content="{l:Localize ClearParameters}"
                            Command="{Binding ClearScriptParametersCommand}" />
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
