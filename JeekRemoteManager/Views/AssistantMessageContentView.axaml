<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:JeekRemoteManager.ViewModels"
             xmlns:views="using:JeekRemoteManager.Views"
             x:Class="JeekRemoteManager.Views.AssistantMessageContentView"
             x:DataType="vm:ChatMessageViewModel">
    <Panel>
        <SelectableTextBlock Text="{Binding Text}"
                             TextWrapping="Wrap"
                             IsVisible="{Binding ShowsPlainText}"
                             Foreground="{DynamicResource TextPrimaryBrush}" />

        <StackPanel Orientation="Horizontal"
                    Spacing="7"
                    VerticalAlignment="Center"
                    IsVisible="{Binding ShowsThinking}">
            <Border Width="7" Height="7" CornerRadius="4"
                    Background="{DynamicResource AccentBrush}"
                    VerticalAlignment="Center" />
            <TextBlock Text="{Binding ThinkingText}"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource TextMutedBrush}" />
        </StackPanel>

        <views:SelectableMarkdownView Markdown="{Binding RenderedMarkdown}"
                                      IsVisible="{Binding ShowsAssistantMarkdown}">
            <views:SelectableMarkdownView.Styles>
                <StyleInclude Source="avares://JeekRemoteManager/Views/AgentChatMarkdown.axaml" />
            </views:SelectableMarkdownView.Styles>
        </views:SelectableMarkdownView>
    </Panel>
</UserControl>
