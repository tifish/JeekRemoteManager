<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:JeekRemoteManager.ViewModels"
             xmlns:l="using:Jeek.Avalonia.Localization"
             xmlns:md="using:Markdown.Avalonia"
             x:Class="JeekRemoteManager.Views.AgentChatView"
             x:DataType="vm:AgentChatViewModel">
    <UserControl.Styles>
        <!-- Codex-style transcript: assistant responses read as the page itself; only
             user messages and exceptional states need a containing card. -->
        <Style Selector="Border.chat-bubble">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="Margin" Value="0,4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
        <Style Selector="Border.chat-user">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Margin" Value="70,5,0,5" />
        </Style>
        <Style Selector="Border.chat-assistant">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,11,20,13" />
        </Style>
        <Style Selector="Border.chat-assistant Panel.message-content">
            <Setter Property="Margin" Value="34,0,0,0" />
        </Style>
        <Style Selector="Border.assistant-avatar">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SelectedBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>
        <Style Selector="Border.chat-system">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
            <Setter Property="BorderThickness" Value="3,0,0,0" />
            <Setter Property="CornerRadius" Value="4,10,10,4" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0,6" />
        </Style>
        <Style Selector="Border.chat-system SelectableTextBlock">
            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
        </Style>
        <Style Selector="Border.chat-tool">
            <Setter Property="Background" Value="{DynamicResource ChromeSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="28,5" />
            <Setter Property="IsVisible"
                    Value="{Binding #MessagesList.((vm:AgentChatViewModel)DataContext).ShowCommandOutput}" />
        </Style>
        <Style Selector="Border.chat-tool SelectableTextBlock">
            <Setter Property="FontFamily" Value="Cascadia Mono,Consolas,Menlo,monospace" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
        </Style>
        <Style Selector="Border.chat-confirm">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="13,11" />
            <Setter Property="Margin" Value="0,7" />
        </Style>

        <!-- Compact, quiet controls keep the header subordinate to the conversation. -->
        <Style Selector="ComboBox.header-option">
            <Setter Property="MinHeight" Value="24" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="7,2" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
        </Style>
        <Style Selector="Button.chat-header-button">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBlock.chat-header-icon">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
        </Style>
        <Style Selector="Border.composer">
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushStrong}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="13" />
        </Style>
        <Style Selector="TextBox.composer-input">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="13" />
            <Setter Property="Padding" Value="12,10" />
        </Style>
        <Style Selector="CheckBox.chat-option">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="Margin" Value="0,0,13,4" />
        </Style>
        <Style Selector="Button.composer-action">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.scroll-to-bottom">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Opacity" Value="0.92" />
            <Setter Property="ZIndex" Value="10" />
        </Style>
        <Style Selector="Button.scroll-to-bottom:pointerover">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
        </Style>
    </UserControl.Styles>

    <DockPanel Background="{DynamicResource SurfaceBrush}">
        <!-- Header -->
        <Border DockPanel.Dock="Top"
                Padding="10,7"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrushSoft}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="7"
                            VerticalAlignment="Center">
                    <Border Width="24" Height="24" CornerRadius="8"
                            Background="{DynamicResource AccentSoftBrush}"
                            BorderBrush="{DynamicResource SelectedBorderBrush}"
                            BorderThickness="1">
                        <TextBlock Text="✦" FontSize="13"
                                   Foreground="{DynamicResource AccentBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="{l:Localize AiAssistant}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- Keep the title bar one line even when the panel is narrow. Model
                     selectors remain reachable through this horizontal strip. -->
                <ScrollViewer Grid.Column="1"
                              HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Disabled"
                              VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <ComboBox Classes="header-option"
                                  ItemsSource="{Binding Providers}"
                                  SelectedItem="{Binding SelectedProvider, Mode=TwoWay}"
                                  IsEnabled="{Binding !IsBusy}"
                                  ToolTip.Tip="{l:Localize AiProvider}"
                                  MinWidth="76">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:AgentProvider">
                                    <TextBlock Text="{Binding Label}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <ComboBox Classes="header-option"
                                  ItemsSource="{Binding ModelOptions}"
                                  SelectedItem="{Binding SelectedModel, Mode=TwoWay}"
                                  IsEnabled="{Binding !IsBusy}"
                                  ToolTip.Tip="{l:Localize AiModel}"
                                  MinWidth="96">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:AgentOption">
                                    <TextBlock Text="{Binding Label}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <ComboBox Classes="header-option"
                                  ItemsSource="{Binding EffortOptions}"
                                  SelectedItem="{Binding SelectedEffort, Mode=TwoWay}"
                                  IsEnabled="{Binding !IsBusy}"
                                  ToolTip.Tip="{l:Localize AiEffort}"
                                  MinWidth="72">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:AgentOption">
                                    <TextBlock Text="{Binding Label}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock Classes="hint"
                                   VerticalAlignment="Center"
                                   MaxWidth="110"
                                   TextTrimming="CharacterEllipsis"
                                   Text="{Binding StatusText}"
                                   ToolTip.Tip="{Binding StatusText}"
                                   IsVisible="{Binding StatusText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="2">
                    <Button Classes="chat-header-button"
                            Command="{Binding NewConversationCommand}"
                            ToolTip.Tip="{l:Localize AiNewConversationHint}">
                        <TextBlock Classes="chat-header-icon" Text="&#xE710;" />
                    </Button>
                    <Button Classes="chat-header-button"
                            Command="{Binding ManageProvidersCommand}"
                            IsEnabled="{Binding !IsBusy}"
                            ToolTip.Tip="{l:Localize AiManageProviders}">
                        <TextBlock Classes="chat-header-icon" Text="&#xE713;" />
                    </Button>
                    <Button Classes="chat-header-button"
                            Click="OnCloseClick"
                            ToolTip.Tip="{l:Localize Close}">
                        <TextBlock Classes="chat-header-icon" FontSize="10" Text="&#xE711;" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Provider unavailable -->
        <Border DockPanel.Dock="Top"
                Padding="12,9"
                IsVisible="{Binding !IsAvailable}"
                Background="{DynamicResource SurfaceAltBrush}"
                BorderBrush="{DynamicResource DangerBrush}"
                BorderThickness="3,0,0,0"
                CornerRadius="4,8,8,4"
                Margin="10,8,10,0">
            <TextBlock Classes="hint" Text="{Binding UnavailableText}" />
        </Border>

        <!-- Composer -->
        <Border DockPanel.Dock="Bottom"
                Classes="composer"
                Margin="10,0,10,10">
            <StackPanel>
                <TextBox x:Name="InputBox"
                         Classes="composer-input"
                         Text="{Binding InputText, Mode=TwoWay}"
                         PlaceholderText="{l:Localize AiInputWatermark}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="68"
                         MaxHeight="150"
                         VerticalContentAlignment="Top" />
                <Border IsVisible="{Binding HasTerminalSelection}"
                        Margin="10,0,10,6"
                        Padding="8,5"
                        Background="{DynamicResource AccentSoftBrush}"
                        CornerRadius="7">
                    <TextBlock Classes="hint"
                               FontSize="11"
                               Foreground="{DynamicResource AccentBrush}"
                               Text="{l:Localize AiSelectionHint}" />
                </Border>
                <Grid ColumnDefinitions="*,Auto" Margin="10,0,8,8" ColumnSpacing="8">
                    <WrapPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <CheckBox Classes="chat-option"
                                  Content="{l:Localize AiAutoRun}"
                                  IsChecked="{Binding AutoRun, Mode=TwoWay}"
                                  ToolTip.Tip="{l:Localize AiAutoRunHint}" />
                        <CheckBox Classes="chat-option"
                                  Content="{l:Localize AiAutoApprove}"
                                  IsChecked="{Binding AutoApproveDangerousCommands, Mode=TwoWay}"
                                  IsEnabled="{Binding AutoRun}"
                                  ToolTip.Tip="{l:Localize AiAutoApproveHint}" />
                        <CheckBox Classes="chat-option"
                                  Content="{l:Localize AiShowOutput}"
                                  IsChecked="{Binding ShowCommandOutput, Mode=TwoWay}"
                                  ToolTip.Tip="{l:Localize AiShowOutputHint}" />
                        <CheckBox Classes="chat-option"
                                  Content="{l:Localize AiAgentMode}"
                                  IsChecked="{Binding AgentMode, Mode=TwoWay}"
                                  ToolTip.Tip="{l:Localize AiAgentModeHint}" />
                    </WrapPanel>
                    <Button Grid.Column="1"
                            Classes="accent composer-action"
                            Command="{Binding SendCommand}"
                            ToolTip.Tip="{l:Localize AiSend}"
                            IsVisible="{Binding !IsBusy}">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   FontSize="13"
                                   Foreground="{DynamicResource AccentForegroundBrush}"
                                   Text="&#xE72A;" />
                    </Button>
                    <Button Grid.Column="1"
                            Classes="composer-action"
                            Command="{Binding StopCommand}"
                            ToolTip.Tip="{l:Localize AiStopHint}"
                            IsVisible="{Binding IsBusy}">
                        <TextBlock FontSize="11" Text="■" />
                    </Button>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Transcript and empty state -->
        <Grid>
            <Border IsVisible="{Binding !HasMessages}"
                    Padding="32"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel Spacing="10" MaxWidth="350" HorizontalAlignment="Center">
                    <Border Width="44" Height="44" CornerRadius="15"
                            Background="{DynamicResource AccentSoftBrush}"
                            BorderBrush="{DynamicResource SelectedBorderBrush}"
                            BorderThickness="1"
                            HorizontalAlignment="Center">
                        <TextBlock Text="✦" FontSize="21"
                                   Foreground="{DynamicResource AccentBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="{l:Localize AiEmptyTitle}"
                               FontSize="17"
                               FontWeight="SemiBold"
                               TextAlignment="Center"
                               HorizontalAlignment="Center" />
                    <TextBlock Classes="hint"
                               Text="{l:Localize AiEmptyHint}"
                               TextAlignment="Center"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <ListBox x:Name="MessagesList"
                     ItemsSource="{Binding Messages}"
                     IsVisible="{Binding HasMessages}"
                     Margin="16,12,16,18"
                     Padding="0"
                     BorderThickness="0"
                     Background="Transparent"
                     Focusable="False"
                     SelectionChanged="OnMessagesSelectionChanged">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel CacheLength="1" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:ChatMessageViewModel">
                            <Border x:Name="ChatBubble"
                                    Classes="chat-bubble"
                                    Classes.chat-user="{Binding IsUser}"
                                    Classes.chat-assistant="{Binding IsAssistant}"
                                    Classes.chat-system="{Binding IsSystem}"
                                    Classes.chat-tool="{Binding IsTool}"
                                    Classes.chat-confirm="{Binding IsConfirmation}">
                                <Border.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="{l:Localize Copy}"
                                                  CommandParameter="{Binding}"
                                                  Click="OnCopyMessageClick" />
                                    </ContextMenu>
                                </Border.ContextMenu>
                                <Panel>
                                    <Border Classes="assistant-avatar"
                                            IsVisible="{Binding IsAssistant}">
                                        <TextBlock Text="✦" FontSize="12"
                                                   Foreground="{DynamicResource AccentBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                    <Panel Classes="message-content">
                                        <SelectableTextBlock Text="{Binding Text}"
                                                             TextWrapping="Wrap"
                                                             IsVisible="{Binding ShowsPlainText}"
                                                             Foreground="{DynamicResource TextPrimaryBrush}" />

                                        <StackPanel IsVisible="{Binding IsConfirmation}" Spacing="8">
                                            <TextBlock Classes="hint"
                                                       Text="{l:Localize AiDangerWarning}"
                                                       Foreground="{DynamicResource DangerBrush}"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                            <SelectableTextBlock Text="{Binding Text}"
                                                                 TextWrapping="Wrap"
                                                                 FontFamily="Cascadia Mono,Consolas,Menlo,monospace"
                                                                 FontSize="12"
                                                                 Foreground="{DynamicResource TextPrimaryBrush}" />
                                            <StackPanel Orientation="Horizontal" Spacing="8"
                                                        IsVisible="{Binding IsAwaitingDecision}">
                                                <Button Classes="accent" MinHeight="28"
                                                        Content="{l:Localize AiRunInTerminal}"
                                                        Command="{Binding #MessagesList.((vm:AgentChatViewModel)DataContext).RunPendingCommandCommand}" />
                                                <Button MinHeight="28"
                                                        Content="{l:Localize AiDangerSkip}"
                                                        Command="{Binding #MessagesList.((vm:AgentChatViewModel)DataContext).SkipPendingCommandCommand}" />
                                            </StackPanel>
                                            <TextBlock Classes="hint"
                                                       Text="{Binding DecisionText}"
                                                       IsVisible="{Binding DecisionText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="7"
                                                    VerticalAlignment="Center"
                                                    IsVisible="{Binding ShowsThinking}">
                                            <Border Width="7" Height="7" CornerRadius="4"
                                                    Background="{DynamicResource AccentBrush}"
                                                    VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding ThinkingText}"
                                                       TextWrapping="Wrap"
                                                       Foreground="{DynamicResource TextMutedBrush}" />
                                        </StackPanel>

                                        <md:MarkdownScrollViewer Markdown="{Binding RenderedMarkdown}"
                                                                 IsVisible="{Binding ShowsAssistantMarkdown}"
                                                                 LayoutUpdated="OnMarkdownLayoutUpdated"
                                                                 SelectionEnabled="True">
                                            <md:MarkdownScrollViewer.Styles>
                                                <StyleInclude Source="avares://JeekRemoteManager/Views/AgentChatMarkdown.axaml" />
                                            </md:MarkdownScrollViewer.Styles>
                                        </md:MarkdownScrollViewer>
                                    </Panel>
                                </Panel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
            </ListBox>

            <!-- Shown when the transcript is scrolled away from the latest messages. -->
            <Button x:Name="ScrollToBottomButton"
                    Classes="scroll-to-bottom"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,18,12"
                    IsVisible="False"
                    Click="OnScrollToBottomClick"
                    ToolTip.Tip="{l:Localize ScrollToLatestHint}">
                <TextBlock FontFamily="Segoe MDL2 Assets"
                           FontSize="14"
                           Foreground="{DynamicResource AccentForegroundBrush}"
                           Text="&#xE74B;"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Button>
        </Grid>
    </DockPanel>
</UserControl>
