<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:JeekRemoteManager.ViewModels"
             xmlns:l="using:Jeek.Avalonia.Localization"
             xmlns:md="using:Markdown.Avalonia"
             xmlns:ctxt="clr-namespace:ColorTextBlock.Avalonia;assembly=ColorTextBlock.Avalonia"
             xmlns:mdc="clr-namespace:Markdown.Avalonia.Controls;assembly=Markdown.Avalonia"
             x:Class="JeekRemoteManager.Views.AgentChatView"
             x:DataType="vm:AgentChatViewModel">
    <UserControl.Styles>
        <Style Selector="Border.chat-bubble">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Margin" Value="0,3" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="Border.chat-user">
            <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SelectedBorderBrush}" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <!-- Owned by the user: hug the right edge, leave a fixed gap on the left. -->
            <Setter Property="Margin" Value="48,3,0,3" />
        </Style>
        <Style Selector="Border.chat-assistant">
            <!-- GitHub dark card, regardless of app theme. -->
            <Setter Property="Background" Value="#0D1117" />
            <Setter Property="BorderBrush" Value="#30363D" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <!-- Owned by the assistant: hug the left edge, leave a fixed gap on the right. -->
            <Setter Property="Margin" Value="0,3,48,3" />
        </Style>
        <Style Selector="Border.chat-system">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
        <Style Selector="Border.chat-tool">
            <Setter Property="Background" Value="{DynamicResource TerminalBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushStrong}" />
            <!-- Command echo/output belongs to neither side: centered, with symmetric gaps. -->
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Margin" Value="12,3" />
            <!-- Hidden from the transcript unless the user opts in (it's also in the terminal). -->
            <Setter Property="IsVisible"
                    Value="{Binding #MessagesList.((vm:AgentChatViewModel)DataContext).ShowCommandOutput}" />
        </Style>
        <Style Selector="Border.chat-tool SelectableTextBlock">
            <Setter Property="FontFamily" Value="Consolas,Menlo,monospace" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TerminalForegroundBrush}" />
        </Style>
        <!-- A dangerous command awaiting the user's decision: always visible, danger-accented. -->
        <Style Selector="Border.chat-confirm">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0,3" />
        </Style>
        <!-- Compact selectors that live in the header bar. -->
        <Style Selector="ComboBox.header-option">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="8,4" />
        </Style>
    </UserControl.Styles>

    <DockPanel Background="{DynamicResource SurfaceBrush}">
        <!-- Header -->
        <Border DockPanel.Dock="Top"
                Padding="12,9"
                Background="{DynamicResource ChromeSurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrushSoft}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto">
            <StackPanel Spacing="3">
                <!-- Title plus the session options; the options wrap below the title when the panel is narrow. -->
                <WrapPanel Orientation="Horizontal">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="0,3,14,3">
                        <Border Width="26" Height="26" CornerRadius="7"
                                Background="{DynamicResource AccentSoftBrush}"
                                BorderBrush="{DynamicResource SelectedBorderBrush}"
                                BorderThickness="1">
                            <TextBlock Text="✦" FontSize="14"
                                       Foreground="{DynamicResource AccentBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Classes="section-title" Text="{l:Localize AiAssistant}" VerticalAlignment="Center" />
                    </StackPanel>
                    <ComboBox Classes="header-option"
                              ItemsSource="{Binding Providers}"
                              SelectedItem="{Binding SelectedProvider, Mode=TwoWay}"
                              IsEnabled="{Binding !IsBusy}"
                              ToolTip.Tip="{l:Localize AiProvider}"
                              VerticalAlignment="Center"
                              MinWidth="88" Margin="0,3,8,3">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:AgentProvider">
                                <TextBlock Text="{Binding Label}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <ComboBox Classes="header-option"
                              ItemsSource="{Binding ModelOptions}"
                              SelectedItem="{Binding SelectedModel, Mode=TwoWay}"
                              IsEnabled="{Binding !IsBusy}"
                              ToolTip.Tip="{l:Localize AiModel}"
                              VerticalAlignment="Center"
                              MinWidth="96" Margin="0,3,8,3">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:AgentOption">
                                <TextBlock Text="{Binding Label}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <ComboBox Classes="header-option"
                              ItemsSource="{Binding EffortOptions}"
                              SelectedItem="{Binding SelectedEffort, Mode=TwoWay}"
                              IsEnabled="{Binding !IsBusy}"
                              ToolTip.Tip="{l:Localize AiEffort}"
                              VerticalAlignment="Center"
                              MinWidth="88" Margin="0,3,8,3">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:AgentOption">
                                <TextBlock Text="{Binding Label}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button MinHeight="28" MinWidth="32" Padding="6,2"
                            FontSize="14"
                            VerticalAlignment="Center" Margin="0,3,0,3"
                            Content="⚙"
                            Command="{Binding ManageProvidersCommand}"
                            IsEnabled="{Binding !IsBusy}"
                            ToolTip.Tip="{l:Localize AiManageProviders}" />
                </WrapPanel>
                <TextBlock Classes="hint" Text="{Binding StatusText}" IsVisible="{Binding StatusText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
            </StackPanel>
            <Button Grid.Column="1"
                    Classes="toolbar"
                    Click="OnCloseClick"
                    ToolTip.Tip="{l:Localize Close}"
                    VerticalAlignment="Top"
                    Margin="8,3,0,0"
                    Width="24" Height="24"
                    MinWidth="0" MinHeight="0"
                    Padding="0"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center">
                <TextBlock Classes="icon" FontSize="9" Text="&#xE711;" />
            </Button>
            </Grid>
        </Border>

        <!-- Not-available banner -->
        <Border DockPanel.Dock="Top"
                Padding="12,9"
                IsVisible="{Binding !IsAvailable}"
                Background="{DynamicResource SurfaceAltBrush}"
                BorderBrush="{DynamicResource DangerBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Margin="8">
            <TextBlock Classes="hint" Text="{Binding UnavailableText}" />
        </Border>

        <!-- Input area -->
        <Border DockPanel.Dock="Bottom"
                Padding="10"
                Background="{DynamicResource ChromeSurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrushSoft}"
                BorderThickness="0,1,0,0">
            <StackPanel Spacing="8">
                <!-- Toggles flow on one row and wrap only when the panel is too narrow. -->
                <WrapPanel Orientation="Horizontal">
                    <Button Margin="0,0,16,6"
                            MinHeight="28"
                            VerticalAlignment="Center"
                            Command="{Binding NewConversationCommand}"
                            Content="{l:Localize AiNewConversation}"
                            ToolTip.Tip="{l:Localize AiNewConversationHint}" />
                    <CheckBox Margin="0,0,16,6" VerticalAlignment="Center"
                              Content="{l:Localize AiAutoRun}"
                              IsChecked="{Binding AutoRun, Mode=TwoWay}"
                              ToolTip.Tip="{l:Localize AiAutoRunHint}" />
                    <CheckBox Margin="0,0,16,6" VerticalAlignment="Center"
                              Content="{l:Localize AiShowOutput}"
                              IsChecked="{Binding ShowCommandOutput, Mode=TwoWay}"
                              ToolTip.Tip="{l:Localize AiShowOutputHint}" />
                    <CheckBox Margin="0,0,0,6" VerticalAlignment="Center"
                              Content="{l:Localize AiAgentMode}"
                              IsChecked="{Binding AgentMode, Mode=TwoWay}"
                              ToolTip.Tip="{l:Localize AiAgentModeHint}" />
                </WrapPanel>
                <!-- Shown while the terminal has a selection: it will ride along with the message. -->
                <TextBlock Classes="hint"
                           Text="{l:Localize AiSelectionHint}"
                           IsVisible="{Binding HasTerminalSelection}" />
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <TextBox Grid.Column="0"
                             x:Name="InputBox"
                             Text="{Binding InputText, Mode=TwoWay}"
                             PlaceholderText="{l:Localize AiInputWatermark}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="60"
                             MaxHeight="140"
                             VerticalContentAlignment="Top" />
                    <Button Grid.Column="1"
                            Classes="accent"
                            VerticalAlignment="Bottom"
                            Command="{Binding SendCommand}"
                            Content="{l:Localize AiSend}"
                            IsVisible="{Binding !IsBusy}" />
                    <Button Grid.Column="1"
                            VerticalAlignment="Bottom"
                            Command="{Binding StopCommand}"
                            Content="{l:Localize AiStop}"
                            ToolTip.Tip="{l:Localize AiStopHint}"
                            IsVisible="{Binding IsBusy}" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- Transcript -->
        <ScrollViewer x:Name="MessagesScroll">
            <ItemsControl x:Name="MessagesList" ItemsSource="{Binding Messages}" Margin="10,10,10,12">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ChatMessageViewModel">
                        <Border x:Name="ChatBubble"
                                Classes="chat-bubble"
                                Classes.chat-user="{Binding IsUser}"
                                Classes.chat-assistant="{Binding IsAssistant}"
                                Classes.chat-system="{Binding IsSystem}"
                                Classes.chat-tool="{Binding IsTool}"
                                Classes.chat-confirm="{Binding IsConfirmation}">
                            <Border.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="{l:Localize Copy}"
                                              CommandParameter="{Binding}"
                                              Click="OnCopyMessageClick" />
                                </ContextMenu>
                            </Border.ContextMenu>
                            <Panel>
                                <!-- Assistant answers are Markdown; user/system/tool are plain text. -->
                                <SelectableTextBlock Text="{Binding Text}"
                                                     TextWrapping="Wrap"
                                                     IsVisible="{Binding IsPlainBubble}"
                                                     Foreground="{DynamicResource TextPrimaryBrush}" />
                                <!-- Dangerous command confirmation card. -->
                                <StackPanel IsVisible="{Binding IsConfirmation}" Spacing="8">
                                    <TextBlock Classes="hint"
                                               Text="{l:Localize AiDangerWarning}"
                                               Foreground="{DynamicResource DangerBrush}"
                                               TextWrapping="Wrap" />
                                    <SelectableTextBlock Text="{Binding Text}"
                                                         TextWrapping="Wrap"
                                                         FontFamily="Consolas,Menlo,monospace"
                                                         FontSize="12"
                                                         Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <StackPanel Orientation="Horizontal" Spacing="8"
                                                IsVisible="{Binding IsAwaitingDecision}">
                                        <Button Classes="accent" MinHeight="28"
                                                Content="{l:Localize AiRunInTerminal}"
                                                Command="{Binding #MessagesList.((vm:AgentChatViewModel)DataContext).RunPendingCommandCommand}" />
                                        <Button MinHeight="28"
                                                Content="{l:Localize AiDangerSkip}"
                                                Command="{Binding #MessagesList.((vm:AgentChatViewModel)DataContext).SkipPendingCommandCommand}" />
                                    </StackPanel>
                                    <TextBlock Classes="hint"
                                               Text="{Binding DecisionText}"
                                               IsVisible="{Binding DecisionText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                </StackPanel>
                                <TextBlock Text="{Binding ThinkingText}"
                                           TextWrapping="Wrap"
                                           IsVisible="{Binding ShowsThinking}"
                                           FontStyle="Italic"
                                           Foreground="#8B949E" />
                                <md:MarkdownScrollViewer Markdown="{Binding Text}"
                                                         IsVisible="{Binding ShowsAssistantMarkdown}"
                                                         SelectionEnabled="True">
                                    <md:MarkdownScrollViewer.Styles>
                                        <StyleInclude Source="avares://JeekRemoteManager/Views/GithubDarkMarkdown.axaml" />
                                    </md:MarkdownScrollViewer.Styles>
                                </md:MarkdownScrollViewer>
                            </Panel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
