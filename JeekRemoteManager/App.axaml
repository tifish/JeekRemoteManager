<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="JeekRemoteManager.App"
             xmlns:local="using:JeekRemoteManager"
             RequestedThemeVariant="Default">
    <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Resources>
        <!-- Terminal primary mono font; CJK missing glyphs use FontManagerOptions.FontFallbacks. -->
        <x:String x:Key="SvcSystems.UI.TerminalFontFamily">Cascadia Mono, Consolas, Microsoft YaHei UI, Microsoft YaHei, NSimSun, Noto Sans SC, monospace</x:String>
        <!-- Balanced ANSI palette for the embedded SSH terminal. -->
        <SolidColorBrush x:Key="SvcSystems.UI.TerminalCaretBrush" Color="#D8E2EA" />
        <SolidColorBrush x:Key="SvcSystems.UI.TerminalSelectionBrush" Color="#405E81AC" />
        <SolidColorBrush x:Key="SvcSystems.UI.TerminalColor0" Color="#151B22" />
        <SolidColorBrush x:Key="SvcSystems.UI.TerminalColor1" Color="#D66F7B" />
        <SolidColorBrush x:Key="SvcSystems.UI.TerminalColor2" Color="#8DCB6E" />
        <SolidColorBrush x:Key="SvcSystems.UI.TerminalColor3" Color="#DDB858" />
        <SolidColorBrush x:Key="SvcSystems.UI.TerminalColor4" Color="#63A4DC" />
        <SolidColorBrush x:Key="SvcSystems.UI.TerminalColor5" Color="#C27CC8" />
        <SolidColorBrush x:Key="SvcSystems.UI.TerminalColor6" Color="#58BFD0" />
        <SolidColorBrush x:Key="SvcSystems.UI.TerminalColor7" Color="#D6DEE8" />
        <SolidColorBrush x:Key="SvcSystems.UI.TerminalColor8" Color="#66717F" />
        <SolidColorBrush x:Key="SvcSystems.UI.TerminalColor9" Color="#EA8791" />
        <SolidColorBrush x:Key="SvcSystems.UI.TerminalColor10" Color="#A4DA82" />
        <SolidColorBrush x:Key="SvcSystems.UI.TerminalColor11" Color="#E8C96E" />
        <SolidColorBrush x:Key="SvcSystems.UI.TerminalColor12" Color="#82BDF0" />
        <SolidColorBrush x:Key="SvcSystems.UI.TerminalColor13" Color="#D794D8" />
        <SolidColorBrush x:Key="SvcSystems.UI.TerminalColor14" Color="#76D5E2" />
        <SolidColorBrush x:Key="SvcSystems.UI.TerminalColor15" Color="#F0F4F8" />

        <!-- Fluent default scaleX/Y(0.125) shrinks hit-testing with the visual.
             Force identity; thin look is painted inside a full-size hit plate. -->
        <TransformOperations x:Key="VerticalSmallScrollThumbScaleTransform">none</TransformOperations>
        <TransformOperations x:Key="HorizontalSmallScrollThumbScaleTransform">none</TransformOperations>
    </Application.Resources>

    <TrayIcon.Icons>
        <TrayIcons>
            <!-- The right-click menu is built in code (App.axaml.cs) so it can
                 mirror the main window's overflow menu and bind to its commands. -->
            <TrayIcon Icon="/Assets/icon.ico"
                      ToolTipText="Jeek Remote Manager"
                      Clicked="OnTrayIconClicked" />
        </TrayIcons>
    </TrayIcon.Icons>

    <Application.Styles>
        <FluentTheme />
        <!-- Terminal control default font + 256-color palette resources. -->
        <StyleInclude Source="avares://SvcSystems.UI.Terminal/Styles/Colors.axaml" />
        <Style Selector="Window">
            <Setter Property="FontFamily" Value="Inter, Segoe UI" />
        </Style>
        <!-- Instant expand (default ShowDelay is 500ms). ScrollBar uses IsExpanded
             property only — there is no :expanded pseudo-class. -->
        <Style Selector="ScrollBar">
            <Setter Property="ShowDelay" Value="0" />
        </Style>
        <!-- Full-size transparent hit plate; visual Border can be thinner without
             shrinking the drag target (Windows-style overlay scrollbar). -->
        <Style Selector="ScrollBar /template/ Thumb">
            <Setter Property="RenderTransform" Value="none" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Panel Background="Transparent">
                        <Border x:Name="thumbVisual"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{TemplateBinding CornerRadius}" />
                    </Panel>
                </ControlTemplate>
            </Setter>
        </Style>
        <!-- Idle: thin strip (IsExpanded is a DirectProperty; use property selector). -->
        <Style Selector="ScrollBar:vertical[IsExpanded=False] /template/ Thumb /template/ Border#thumbVisual">
            <Setter Property="Width" Value="4" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Margin" Value="0,0,1,0" />
        </Style>
        <Style Selector="ScrollBar:horizontal[IsExpanded=False] /template/ Thumb /template/ Border#thumbVisual">
            <Setter Property="Height" Value="4" />
            <Setter Property="VerticalAlignment" Value="Bottom" />
            <Setter Property="Margin" Value="0,0,0,1" />
        </Style>
        <!-- Hover/expanded: full-size thumb paint. -->
        <Style Selector="ScrollBar[IsExpanded=True] /template/ Thumb /template/ Border#thumbVisual">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="Width" Value="NaN" />
            <Setter Property="Height" Value="NaN" />
            <Setter Property="Margin" Value="0" />
        </Style>
        <!-- Color emoji icons: Inter (the default font) is monochrome-only,
             so route any TextBlock tagged with the "emoji" class through
             Segoe UI Emoji to get the color glyphs back. -->
        <Style Selector="TextBlock.emoji">
            <Setter Property="FontFamily" Value="Segoe UI Emoji" />
        </Style>
        <Style Selector="TextBlock.icon">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Application.Styles>
</Application>
